-- =====================================================================
-- HOTEL SISTEMA - Esquema de base de datos
-- Mejoras aplicadas sobre la version original:
--   1. usuarios.password_hash  -> login local para usuarios sin Google
--   2. usuarios.fecha_creacion -> auditoria de alta de cuenta
--   3. reservas.usuario_id / habitacion_id -> ahora NOT NULL
--   4. reservas.fecha_creacion -> fecha en que se genero la reserva
--      (distinta de fecha_hora_entrada, que es el check-in real)
--   5. reserva_productos.reserva_id / producto_id -> ahora NOT NULL
--   6. pagos.reserva_id -> ahora NOT NULL
--   7. Indice extra en reservas para consultas de disponibilidad
-- =====================================================================

-- 1. USUARIOS (Maneja los 3 roles y el login con Google)
CREATE TABLE usuarios (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    apellidos VARCHAR(100),
    email VARCHAR(150) UNIQUE NOT NULL,
    telefono VARCHAR(20),
    rol ENUM('ADMINISTRADOR', 'RECEPCIONISTA', 'CLIENTE') NOT NULL,
    google_auth BOOLEAN DEFAULT FALSE,
    password_hash VARCHAR(255) DEFAULT NULL, -- NULL si google_auth = TRUE
    activo BOOLEAN DEFAULT TRUE,
    fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB;

-- 2. HABITACIONES (Inventario físico de las 24 habitaciones)
CREATE TABLE habitaciones (
    id INT AUTO_INCREMENT PRIMARY KEY,
    numero_habitacion VARCHAR(10) NOT NULL UNIQUE, -- Ej: '101', '204'
    tipo ENUM('SIMPLE', 'DOBLE', 'TRIPLE', 'MATRIMONIAL') NOT NULL,
    precio_dia DECIMAL(10, 2) NOT NULL,
    precio_hora DECIMAL(10, 2) NOT NULL,
    estado ENUM('LIBRE', 'OCUPADO', 'MANTENIMIENTO') DEFAULT 'LIBRE',
    activo BOOLEAN DEFAULT TRUE -- Para ocultar sin borrar
) ENGINE=InnoDB;

-- 3. CATEGORÍAS DE PRODUCTOS (Para el admin)
CREATE TABLE categorias (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL, -- Ej: 'Kiosko', 'Licores'
    activo BOOLEAN DEFAULT TRUE
) ENGINE=InnoDB;

-- 4. PRODUCTOS (Con eliminación lógica)
CREATE TABLE productos (
    id INT AUTO_INCREMENT PRIMARY KEY,
    categoria_id INT,
    nombre VARCHAR(150) NOT NULL,
    precio DECIMAL(10, 2) NOT NULL,
    imagen_url VARCHAR(255),
    activo BOOLEAN DEFAULT TRUE,
    FOREIGN KEY (categoria_id) REFERENCES categorias(id) ON DELETE SET NULL
) ENGINE=InnoDB;

-- 5. RESERVAS (El núcleo del sistema. Soporta horas y días)
CREATE TABLE reservas (
    id INT AUTO_INCREMENT PRIMARY KEY,
    usuario_id INT NOT NULL,
    habitacion_id INT NOT NULL,
    modalidad ENUM('POR_DIA', 'POR_HORAS') NOT NULL,
    fecha_hora_entrada DATETIME NOT NULL,
    fecha_hora_salida DATETIME NOT NULL,
    cant_adultos INT DEFAULT 1,
    cant_ninos INT DEFAULT 0,
    acceso_piscina BOOLEAN DEFAULT FALSE,

    -- Desglose de costos para que la boleta cuadre
    costo_habitacion DECIMAL(10, 2) NOT NULL,
    costo_piscina DECIMAL(10, 2) DEFAULT 0.00,
    costo_productos DECIMAL(10, 2) DEFAULT 0.00,
    total_general DECIMAL(10, 2) NOT NULL,

    estado ENUM('PENDIENTE', 'PAGADA', 'FINALIZADA', 'ANULADA') DEFAULT 'PENDIENTE',
    fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP(),

    FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE RESTRICT,
    FOREIGN KEY (habitacion_id) REFERENCES habitaciones(id) ON DELETE RESTRICT
) ENGINE=InnoDB;

-- Indice de apoyo para consultas de disponibilidad por habitacion/fecha
CREATE INDEX idx_reservas_disponibilidad ON reservas (habitacion_id, fecha_hora_entrada, fecha_hora_salida);

-- 6. CARRITO / DETALLE DE PRODUCTOS EN LA RESERVA
CREATE TABLE reserva_productos (
    id INT AUTO_INCREMENT PRIMARY KEY,
    reserva_id INT NOT NULL,
    producto_id INT NOT NULL,
    cantidad INT NOT NULL,
    precio_unitario DECIMAL(10, 2) NOT NULL,
    subtotal DECIMAL(10, 2) AS (cantidad * precio_unitario) STORED,
    FOREIGN KEY (reserva_id) REFERENCES reservas(id) ON DELETE CASCADE,
    FOREIGN KEY (producto_id) REFERENCES productos(id) ON DELETE RESTRICT
) ENGINE=InnoDB;

-- 7. PASARELA DE PAGOS (Simulación de Yape, Débito, Crédito)
CREATE TABLE pagos (
    id INT AUTO_INCREMENT PRIMARY KEY,
    reserva_id INT NOT NULL,
    metodo ENUM('TARJETA_CREDITO', 'TARJETA_DEBITO', 'YAPE') NOT NULL,
    monto_pagado DECIMAL(10, 2) NOT NULL,
    estado ENUM('APROBADO', 'RECHAZADO') DEFAULT 'APROBADO',
    fecha_pago TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (reserva_id) REFERENCES reservas(id) ON DELETE CASCADE
) ENGINE=InnoDB;


-- ------------------------------------------
-- 1. Actualizar tabla USUARIOS
ALTER TABLE usuarios 
MODIFY COLUMN rol ENUM('ADMINISTRADOR', 'RECEPCIONISTA', 'CLIENTE') NOT NULL;

-- 2. Actualizar tabla RESERVAS
ALTER TABLE reservas 
MODIFY COLUMN modalidad ENUM('POR_DIA', 'POR_HORAS') NOT NULL,
MODIFY COLUMN estado ENUM('PENDIENTE', 'PAGADA', 'FINALIZADA', 'ANULADA') DEFAULT 'PENDIENTE';

-- 3. Actualizar tabla PAGOS
ALTER TABLE pagos 
MODIFY COLUMN metodo ENUM('TARJETA_CREDITO', 'TARJETA_DEBITO', 'YAPE') NOT NULL,
MODIFY COLUMN estado ENUM('APROBADO', 'RECHAZADO') DEFAULT 'APROBADO';

ALTER TABLE habitaciones 
MODIFY COLUMN tipo ENUM('SIMPLE', 'DOBLE', 'TRIPLE', 'MATRIMONIAL') NOT NULL,
MODIFY COLUMN estado ENUM('LIBRE', 'OCUPADO', 'MANTENIMIENTO') DEFAULT 'LIBRE';

ALTER TABLE habitaciones 
ADD COLUMN imagen_url varchar(255) DEFAULT NULL AFTER estado;
